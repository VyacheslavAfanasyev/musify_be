{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "./",
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "resolvePackageJsonExports": false,
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "paths": {
      "@app/shared": ["../../shared/index.ts"],
      "@app/shared/*": ["../../shared/*"]
    }
  },
  "include": ["src/**/*", "../../shared/**/*"]
}
